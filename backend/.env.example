# ──────────────────────────────────────────
#  DiabetesAI Backend — Environment Config
# ──────────────────────────────────────────

# Database
DATABASE_URL=postgresql://diabetes_admin:diabetes_password123!@localhost:5432/diabetes_db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# JWT Auth
SECRET_KEY=change-this-to-a-random-64-char-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# SMTP for email reports (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_NAME=DiabetesAI
